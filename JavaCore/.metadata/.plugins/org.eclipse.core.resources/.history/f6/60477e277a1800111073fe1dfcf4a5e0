package assignment2_2;

public class CreditCardPayment extends Payment {
	
	private String cardNumber;
	private String cvvString;
	private String expiryDateString;
	

	public CreditCardPayment(String transactionId, double amount, String cutomerName, String cardNumber,
			String cvvString, String expiryDateString) {
		super(transactionId, amount, cutomerName);
		this.cardNumber = cardNumber;
		this.cvvString = cvvString;
		this.expiryDateString = expiryDateString;
	}


	public String getCardNumber() {
		return cardNumber;
	}


	public void setCardNumber(String cardNumber) {
		this.cardNumber = cardNumber;
	}


	public String getCvvString() {
		return cvvString;
	}


	public void setCvvString(String cvvString) {
		this.cvvString = cvvString;
	}


	public String getExpiryDateString() {
		return expiryDateString;
	}


	public void setExpiryDateString(String expiryDateString) {
		this.expiryDateString = expiryDateString;
	}

	public boolean validatePayment() {
		
		boolean validCard = cardNumber.length() == 16;
	    boolean validCvv = cvvString.length() == 3;

	    return validCard && validCvv;
		
		
	}
	
	public boolean processPayment() {
		
		return false;
	}

}
